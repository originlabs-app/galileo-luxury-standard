  "assertions": [
    {
      "id": "VAL-PROD-007",
      "title": "Get product detail",
      "status": "pass",
      "steps": [
        {
          "action": "GET /products/:id for existing product",
          "expected": "Returns product with passport and events array",
          "observed": "Returned 200 with passport and CREATED event"
        },
        {
          "action": "GET /products/:id for non-existent product",
          "expected": "Returns 404",
          "observed": "Returned 404 NOT_FOUND"
        },
        {
          "action": "GET /products/:id for other brand's product",
          "expected": "Returns 403/404",
          "observed": "Returned 403 FORBIDDEN"
        }
      ],
      "evidence": {
        "network": "GET /products/:id -> 200 OK, GET /products/invalid -> 404, GET /products/other-brand -> 403"
      },
      "issues": null
    },
    {
      "id": "VAL-PROD-008",
      "title": "Update DRAFT product",
      "status": "pass",
      "steps": [
        {
          "action": "PATCH /products/:id with name, description, category",
          "expected": "Returns 200, creates UPDATED event",
          "observed": "Returned 200, UPDATED event present in product response"
        },
        {
          "action": "PATCH /products/:id with restricted fields (gtin, serialNumber, did, status)",
          "expected": "Returns 400 or ignores them",
          "observed": "Returned 400 VALIDATION_ERROR 'Only name, description, and category can be updated.'"
        }
      ],
      "evidence": {
        "network": "PATCH /products/:id -> 200 OK, PATCH /products/:id with restricted -> 400"
      },
      "issues": null
    },
    {
      "id": "VAL-PROD-009",
      "title": "Update non-DRAFT product rejected",
      "status": "pass",
      "steps": [
        {
          "action": "Update product status to ACTIVE in DB",
          "expected": "Status updated",
          "observed": "Status updated via psql"
        },
        {
          "action": "PATCH /products/:id on ACTIVE product",
          "expected": "Returns 400/422",
          "observed": "Returned 400 BAD_REQUEST 'Cannot update a non-DRAFT product'"
        }
      ],
      "evidence": {
        "network": "PATCH /products/:id -> 400"
      },
      "issues": null
    },
    {
      "id": "VAL-PROD-010",
      "title": "Product CRUD auth enforcement",
      "status": "pass",
      "steps": [
        {
          "action": "POST, GET list, GET detail, PATCH without auth",
          "expected": "Returns 401",
          "observed": "All returned 401 UNAUTHORIZED"
        },
        {
          "action": "POST, PATCH with VIEWER role",
          "expected": "Returns 403",
          "observed": "Both returned 403 FORBIDDEN 'Insufficient permissions'"
        },
        {
          "action": "PATCH on other brand's product",
          "expected": "Returns 403/404",
          "observed": "Returned 403 FORBIDDEN 'Access denied'"
        }
      ],
      "evidence": {
        "network": "Without auth -> 401, With wrong role -> 403, Other brand -> 403"
      },
      "issues": null
    }
  ],
