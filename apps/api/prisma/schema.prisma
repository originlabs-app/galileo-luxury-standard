generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  BRAND_ADMIN
  OPERATOR
  VIEWER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  TRANSFERRED
  RECALLED
}

enum EventType {
  CREATED
  UPDATED
  TRANSFERRED
  VERIFIED
  RECALLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  brandId      String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand  Brand?         @relation(fields: [brandId], references: [id])
  events ProductEvent[]

  @@index([email])
  @@index([brandId])
}

model Brand {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  did       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  products Product[]

  @@index([slug])
}

model Product {
  id           String        @id @default(cuid())
  gtin         String
  serialNumber String
  did          String        @unique
  name         String
  description  String?
  category     String
  status       ProductStatus @default(DRAFT)
  brandId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  brand    Brand            @relation(fields: [brandId], references: [id])
  passport ProductPassport?
  events   ProductEvent[]

  @@unique([gtin, serialNumber])
  @@index([brandId])
  @@index([status])
  @@index([gtin])
}

model ProductPassport {
  id          String   @id @default(cuid())
  productId   String   @unique
  digitalLink String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
}

model ProductEvent {
  id          String    @id @default(cuid())
  productId   String
  type        EventType
  data        Json      @default("{}")
  performedBy String
  createdAt   DateTime  @default(now())

  product   Product @relation(fields: [productId], references: [id])
  performer User    @relation(fields: [performedBy], references: [id])

  @@index([productId])
  @@index([performedBy])
  @@index([type])
}
