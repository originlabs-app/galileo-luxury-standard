# Database connection string (PostgreSQL)
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/galileo_dev"

# JWT secrets (minimum 32 characters each)
JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server port (default: 4000)
PORT=4000

# Allowed CORS origin (default: http://localhost:3000)
CORS_ORIGIN="http://localhost:3000"

# Node environment
NODE_ENV="development"

# Password used by the seed script to create the default admin user
SEED_ADMIN_PASSWORD="change-me-in-production"
