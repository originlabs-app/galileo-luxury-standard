# Database connection string (PostgreSQL)
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/galileo_dev"

# JWT secrets (minimum 32 characters each)
JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server port (default: 4000)
PORT=4000

# Allowed CORS origin (default: http://localhost:3000)
CORS_ORIGIN="http://localhost:3000"

# Node environment
NODE_ENV="development"

# Password used by the seed script to create the default admin user
SEED_ADMIN_PASSWORD="change-me-in-production"

# ── Blockchain (Base Sepolia) ──────────────────────────────────────────────────
# Run `node scripts/setup-wallet.mjs` to generate a fresh mnemonic wallet.

# BIP-39 mnemonic — 12 or 24 words (recommended; preferred over raw private key)
# MINTING_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# Derived wallet address (informational — set by setup-wallet.mjs)
# MINTING_WALLET_ADDRESS=0x...

# Raw private key fallback — only if MINTING_MNEMONIC is not set (legacy)
# DEPLOYER_PRIVATE_KEY=0x...

# Base Sepolia RPC endpoint (get a free key at https://www.alchemy.com or https://www.infura.io)
# BASE_SEPOLIA_RPC_URL="https://base-sepolia.g.alchemy.com/v2/YOUR_KEY"
