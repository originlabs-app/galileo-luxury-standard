{
  "name": "@galileo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "latest",
    "@fastify/jwt": "latest",
    "@fastify/swagger": "latest",
    "@fastify/swagger-ui": "latest",
    "@galileo/shared": "workspace:*",
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "bcrypt": "latest",
    "dotenv": "latest",
    "fastify": "latest",
    "fastify-plugin": "latest",
    "pg": "latest",
    "prisma": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/bcrypt": "latest",
    "@types/pg": "latest",
    "eslint": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
