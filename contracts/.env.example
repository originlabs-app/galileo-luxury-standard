# ============================================================
# Galileo Protocol — Deployment Environment
# ============================================================
# Copy to .env and fill in values. NEVER commit .env files.
#
# For testnet (Base Sepolia):
#   cp .env.example .env
#   Fill in your testnet private key and RPC URL
#   forge script script/Deploy.s.sol --rpc-url $BASE_SEPOLIA_RPC --broadcast
#
# For mainnet (Base):
#   Use a hardware wallet or Safe multisig, NOT a raw private key.
# ============================================================

# ─── Network RPC URLs ───
# Get free endpoints: https://www.alchemy.com or https://www.quicknode.com
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Deployer Wallet ───
# TESTNET ONLY — use a dedicated testnet wallet, never your main wallet
# Fund with Sepolia ETH: https://docs.base.org/tools/network-faucets
DEPLOYER_PRIVATE_KEY=0x_YOUR_TESTNET_PRIVATE_KEY_HERE

# ─── Contract Verification ───
# Get API key: https://basescan.org/myapikey
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ─── Deployed Addresses (filled after deployment) ───
# These are populated by the deploy script output
ACCESS_CONTROL=
CLAIM_TOPICS_REGISTRY=
TRUSTED_ISSUERS_REGISTRY=
IDENTITY_REGISTRY_STORAGE=
IDENTITY_REGISTRY=
COMPLIANCE=
TOKEN_FACTORY=

# ─── Compliance Module Addresses ───
BRAND_AUTH_MODULE=
CPO_CERT_MODULE=
JURISDICTION_MODULE=
SANCTIONS_MODULE=
SERVICE_CENTER_MODULE=

# ─── T1 Token (Phase 6) ───
T1_TOKEN=
PAYMASTER=
STAKING_ACCESS=
MIGRATION_PORTAL=
