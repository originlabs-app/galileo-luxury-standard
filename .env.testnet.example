# ============================================================
# Galileo Protocol — Testnet Environment (Full Stack)
# ============================================================
# Copy to .env.testnet and fill in values. NEVER commit .env files.
# ============================================================

# ─── Blockchain ───
CHAIN_ID=84532
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0x_YOUR_TESTNET_PRIVATE_KEY
BASESCAN_API_KEY=YOUR_KEY

# ─── Backend API ───
DATABASE_URL=postgres://galileo:galileo_dev@localhost:5432/galileo_testnet
PORT=4000
JWT_SECRET=your-testnet-jwt-secret-change-me
CORS_ORIGIN=http://localhost:3000

# ─── Object Storage (R2 / S3) ───
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=galileo-testnet
R2_PUBLIC_URL=https://assets-testnet.galileoprotocol.io

# ─── Wallet / Auth ───
SIWE_DOMAIN=localhost
SIWE_ORIGIN=http://localhost:3000

# ─── Contract Addresses (filled after testnet deploy) ───
GALILEO_TOKEN_FACTORY=0x...
GALILEO_COMPLIANCE=0x...
IDENTITY_REGISTRY=0x...
ACCESS_CONTROL=0x...

# ─── T1 Token (Phase 6) ───
T1_TOKEN_ADDRESS=0x...
PAYMASTER_ADDRESS=0x...

# ─── External Services ───
# KYC provider (Sumsub/Onfido) — needed for T1 migration portal
KYC_API_KEY=
KYC_API_SECRET=

# Price feed for Paymaster (Chainlink/Pyth)
PRICE_FEED_T1_ETH=0x...
